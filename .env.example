# === Required ===
GITHUB_REPO=yourusername/your-repo
GITHUB_WEBHOOK_SECRET=generate-a-random-string-here

# === GitHub Auth — choose ONE ===

# Option A: GitHub App (recommended)
# Run /setup-github-app to create the app and get these values.
# The bot will appear as "your-app-name[bot]" on commits, PRs, and comments.
# GITHUB_APP_ID=123456
# GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# GITHUB_APP_INSTALLATION_ID=78901234
# GITHUB_BOT_NAME=your-app-name[bot]
# GITHUB_BOT_EMAIL=123456+your-app-name[bot]@users.noreply.github.com

# Option B: Personal Access Token (simpler, but commits appear as your user account)
# Needs scopes: repo, workflow
# GITHUB_TOKEN=ghp_your-personal-access-token
# GITHUB_BOT_NAME=Claude Agent
# GITHUB_BOT_EMAIL=claude-agent@noreply

# Claude Code billing — pick ONE:
# Option A: API billing (usage-based, pay per token)
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_USE_MAX=false

# Option B: Claude Max subscription billing (flat monthly rate)
# ANTHROPIC_API_KEY=       ← leave empty or unset
# CLAUDE_USE_MAX=true      ← uses your Max plan

# === Optional ===
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# === Defaults (override if needed) ===
REPO_DIR=/data/repo
TASKS_DIR=/data/tasks
PORT=5000
POLL_INTERVAL=60
MAX_RETRIES_PER_TASK=3
CLAUDE_TIMEOUT=1800
TRIGGER_LABEL=claude
